#!/usr/bin/env bash
# bin/setup — Install qa-agentic-team skills as symlinks into ~/.claude/skills/
#
# Usage:
#   bash bin/setup                          # Symlink skills under short names; prompt for hook
#   bash bin/setup --namespaced             # Single namespaced symlink
#   bash bin/setup --with-hook              # Skip prompt — install Stop hook unattended
#   bash bin/setup --no-hook                # Skip hook entirely
#   bash bin/setup --hook-only              # Don't touch symlinks; install/update hook only
#
# The Stop hook (~/.claude/settings.json) wires bin/qa-team-suggest-rerun to fire on every
# session end, printing a passive nudge when test files have changed since the last QA run.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLAUDE_SKILLS="${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}"
CLAUDE_SETTINGS="${CLAUDE_SETTINGS_FILE:-$HOME/.claude/settings.json}"

# Parse args. Mutually exclusive: --short-names | --namespaced.
# Independent: --with-hook | --no-hook | --hook-only.
MODE="--short-names"
HOOK_PREF="prompt"     # prompt | install | skip
INSTALL_SKILLS=1

for arg in "$@"; do
  case "$arg" in
    --short-names) MODE="--short-names" ;;
    --namespaced)  MODE="--namespaced" ;;
    --with-hook)   HOOK_PREF="install" ;;
    --no-hook)     HOOK_PREF="skip" ;;
    --hook-only)   HOOK_PREF="install"; INSTALL_SKILLS=0 ;;
    *)
      echo "ERROR: unknown argument: $arg" >&2
      sed -n '3,12p' "$0" >&2
      exit 1
      ;;
  esac
done

_version() { cat "$REPO_DIR/VERSION" | tr -d '[:space:]'; }

echo "qa-agentic-team $(_version) — Setup"
echo "========================================"
echo "Repo:     $REPO_DIR"
echo "Skills:   $CLAUDE_SKILLS"
echo "Settings: $CLAUDE_SETTINGS"
echo "Mode:     $MODE"
echo ""

mkdir -p "$CLAUDE_SKILLS"

# Discover skill directories (dirs with a SKILL.md at the repo root)
_skills() {
  find "$REPO_DIR" -maxdepth 2 -name "SKILL.md" \
    ! -path "*/node_modules/*" ! -path "*/.git/*" \
    | while read -r f; do
        skill_dir="$(dirname "$f")"
        # Only top-level skill dirs (direct children of repo root)
        parent="$(dirname "$skill_dir")"
        [ "$parent" = "$REPO_DIR" ] && echo "$skill_dir"
      done
}

INSTALLED=0
UPDATED=0
SKIPPED=0

if [ "$INSTALL_SKILLS" = "0" ]; then
  echo "  (skipping skill symlinks — --hook-only)"
elif [ "$MODE" = "--namespaced" ]; then
  # Single symlink: ~/.claude/skills/qa-agentic-team → repo root
  DEST="$CLAUDE_SKILLS/qa-agentic-team"
  if [ -L "$DEST" ]; then
    OLD_TARGET="$(readlink "$DEST")"
    if [ "$OLD_TARGET" = "$REPO_DIR" ]; then
      echo "  OK    qa-agentic-team (already linked)"
      SKIPPED=1
    else
      rm "$DEST"
      ln -s "$REPO_DIR" "$DEST"
      echo "  UPDATE qa-agentic-team → $REPO_DIR"
      UPDATED=1
    fi
  else
    [ -d "$DEST" ] && rm -rf "$DEST"
    ln -s "$REPO_DIR" "$DEST"
    echo "  LINK  qa-agentic-team → $REPO_DIR"
    INSTALLED=1
  fi
else
  # Short names: one symlink per skill
  while IFS= read -r skill_dir; do
    skill_name="$(basename "$skill_dir")"
    dest="$CLAUDE_SKILLS/$skill_name"

    if [ -L "$dest" ]; then
      OLD_TARGET="$(readlink "$dest")"
      if [ "$OLD_TARGET" = "$skill_dir" ]; then
        echo "  OK    /$skill_name (up to date)"
        SKIPPED=$((SKIPPED + 1))
        continue
      fi
      rm "$dest"
      ln -s "$skill_dir" "$dest"
      echo "  UPDATE /$skill_name → $skill_dir"
      UPDATED=$((UPDATED + 1))
    else
      [ -d "$dest" ] && rm -rf "$dest"
      ln -s "$skill_dir" "$dest"
      echo "  LINK  /$skill_name → $skill_dir"
      INSTALLED=$((INSTALLED + 1))
    fi
  done < <(_skills)
fi

if [ "$INSTALL_SKILLS" = "1" ]; then
  echo ""
  echo "Skill symlinks: Installed: $INSTALLED  Updated: $UPDATED  Skipped: $SKIPPED"
fi

# Install QA agents to ~/.claude/agents/
echo ""
echo "Installing QA agents..."
mkdir -p "$HOME/.claude/agents"
_AGENTS_INSTALLED=0
for _agent_file in "$REPO_DIR/.claude/agents"/*.md; do
  [ -f "$_agent_file" ] || continue
  _agent_name=$(basename "$_agent_file")
  ln -sf "$_agent_file" "$HOME/.claude/agents/$_agent_name"
  echo "  Linked agent: $_agent_name"
  _AGENTS_INSTALLED=$((_AGENTS_INSTALLED + 1))
done
echo "Agents installed: $_AGENTS_INSTALLED"

# ---- Stop hook (re-run nudge) ---------------------------------------------------
HOOK_SCRIPT="$REPO_DIR/bin/qa-team-suggest-rerun"
HOOK_MATCHER="main-agent"

_hook_already_installed() {
  # Returns 0 if a Stop hook entry with the correct nested shape is present.
  [ -f "$CLAUDE_SETTINGS" ] || return 1
  command -v jq >/dev/null 2>&1 || return 2
  jq -e --arg cmd "$HOOK_SCRIPT" \
    'first(.hooks.Stop[]?.hooks[]? | select(.type == "command" and .command == $cmd))' \
    "$CLAUDE_SETTINGS" >/dev/null 2>&1
}

_install_hook() {
  if [ ! -x "$HOOK_SCRIPT" ]; then
    chmod +x "$HOOK_SCRIPT" 2>/dev/null || true
  fi

  if ! command -v jq >/dev/null 2>&1; then
    echo ""
    echo "WARN  jq not installed — cannot edit $CLAUDE_SETTINGS automatically."
    echo "      Add this entry manually under .hooks.Stop:"
    cat <<JSON
        {
          "matcher": "$HOOK_MATCHER",
          "hooks": [{"type": "command", "command": "$HOOK_SCRIPT"}]
        }
JSON
    return 0
  fi

  mkdir -p "$(dirname "$CLAUDE_SETTINGS")"
  if [ ! -f "$CLAUDE_SETTINGS" ]; then
    echo '{}' > "$CLAUDE_SETTINGS"
  fi

  if _hook_already_installed; then
    echo "  OK    Stop hook already installed ($HOOK_SCRIPT)"
    return 0
  fi

  # Atomic merge: read settings → add hook → write to tmp → mv into place.
  local TMP
  TMP="$(mktemp)"
  jq --arg cmd "$HOOK_SCRIPT" --arg matcher "$HOOK_MATCHER" \
    '.hooks.Stop = (
      (.hooks.Stop // [])
      | map(select(not (.matcher == $matcher and .command == $cmd)))
      + [{matcher: $matcher, hooks: [{type: "command", command: $cmd}]}]
    )' \
    "$CLAUDE_SETTINGS" > "$TMP"
  mv "$TMP" "$CLAUDE_SETTINGS"
  echo "  HOOK  installed: Stop / $HOOK_MATCHER → $HOOK_SCRIPT"
}

case "$HOOK_PREF" in
  install)
    echo ""
    echo "Stop hook (auto re-run nudge):"
    _install_hook
    ;;
  skip)
    echo ""
    echo "Stop hook: skipped (--no-hook)."
    echo "  To install later:  bash bin/setup --hook-only"
    ;;
  prompt)
    echo ""
    echo "Stop hook (auto re-run nudge):"
    if _hook_already_installed; then
      echo "  OK    already installed"
    else
      printf "  Install? [Y/n] "
      # Be defensive — if stdin is not a TTY (e.g. CI), default to yes.
      if [ -t 0 ]; then
        read -r reply || reply=""
      else
        reply=""
        echo "(non-interactive: defaulting to yes)"
      fi
      case "$reply" in
        n|N|no|NO|No) echo "  skipped (you can run 'bash bin/setup --hook-only' later)" ;;
        *) _install_hook ;;
      esac
    fi
    ;;
esac

echo ""
echo "Available commands:"
echo "  /qa-team               — Run all agents (auto-detects project type)"
echo "  /qa-web                — Web E2E (Playwright / Cypress / Selenium)"
echo "  /qa-api                — API contract tests (language-driven)"
echo "  /qa-mobile             — Mobile tests (Detox / Appium / Maestro)"
echo "  /qa-perf               — Performance tests (k6 / JMeter / Locust)"
echo "  /qa-visual             — Visual regression (Playwright screenshots)"
echo "  /qa-audit              — Test methodology audit (pyramid, isolation, flakiness)"
echo "  /qa-refine             — Generate tool-specific best-practice guides"
echo "  /qa-methodology-refine — Generate methodology best-practice guides"
echo "  /lang-refine           — Generate language best-practice guides"
echo "  /qa-meta-eval          — Adversarial red-teaming eval of QA skill outputs"
echo "  /qa-manager            — Epic → Playwright pipeline / Figma → TCMS test cases"
echo "  /qa-secrets            — TruffleHog git history + staged diff secrets scan"
echo "  /qa-sca                — Syft SBOM + Grype CVE + license compliance scan"
echo "  /qa-slsa               — SLSA provenance attestation verification"
echo "  /qa-env-parity         — Env var drift detection across dev/staging/prod"
echo "  /qa-test-lint          — Static test smell scanner (sleep, no-assert, magic numbers)"
echo "  /qa-test-order         — Randomized test order → detect order-dependent failures"
echo "  /qa-test-docs          — LLM reads test files → human-readable Markdown docs"
echo "  /qa-coverage-gate      — Per-file coverage delta gate with LLM stub suggestions"
echo "  /qa-report             — Aggregate all CTRF files → unified sprint/PR dashboard"
echo "  /qa-cost               — Token cost tracking across QA runs; CI budget gate"
echo "  /qa-eval-gate          — CI gate: evals/ pass-rate must meet threshold before merge"
echo "  /qa-intent-assert      — NL code property assertions (*.intent.yaml) via LLM judge"
echo "  /qa-geo                — Playwright timezone + geolocation simulation matrix"
echo "  /qa-deeplinks          — Deep link / universal link validator (AASA, assetlinks)"
echo "  /qa-deps               — Testcontainers/docker-compose service dependency smoke test"
echo "  /qa-ci-trace           — OTel build trace analysis → CI optimization recommendations"
echo "  /qa-spec-to-test       — Markdown PRD/spec → YAML test plan → Playwright skeletons"
