#!/usr/bin/env bash
# bin/qa-team-persist-history — Copy a sub-skill's score JSON + report MD into
# <repo>/.qa-team/, with a `<skill>-latest.json` symlink for trend tooling.
#
# Extracts the ~10-line block previously duplicated as Phase Xc in 6 sub-skills
# (qa-audit, qa-api, qa-web, qa-visual, qa-perf, qa-mobile). Centralizes the
# delta-mode skip rule too — only qa-audit had it inline; now any sub-skill
# that sets `delta_mode.enabled=true` in its sidecar gets the same treatment
# automatically.
#
# Usage:
#   bash bin/qa-team-persist-history <skill-name>
#
# Inputs (read from $TMP):
#   $TMP/<skill-name>-score.json   (required for persistence)
#   $TMP/<skill-name>-report.md    (optional — copied if present)
#
# Behaviour:
#   - If the score JSON has `delta_mode.enabled == true` (jq required), skip
#     persistence with a clear message — delta runs are transient by design.
#   - Outside a git repo: silently skip (returns 0).
#   - Score JSON missing: silently skip (returns 0). Report-only persistence
#     would corrupt the trend pointer.
#   - On success: writes
#       <repo>/.qa-team/<skill-name>-<commit>-<utctimestamp>.{json,md}
#       <repo>/.qa-team/<skill-name>-latest.json -> <key>.json
#     and prints a HISTORY: confirmation line.
#
# Exit code: always 0. Persistence never blocks the wrapping skill.

set -e

SKILL="${1:-}"
if [ -z "$SKILL" ]; then
  echo "usage: $(basename "$0") <skill-name>" >&2
  exit 0
fi

TMP_DIR="${TEMP:-${TMP:-/tmp}}"
SCORE="$TMP_DIR/${SKILL}-score.json"
REPORT="$TMP_DIR/${SKILL}-report.md"

# Score JSON is mandatory — without it there's nothing to record.
if [ ! -f "$SCORE" ]; then
  exit 0
fi

# Delta-mode skip: any skill that sets delta_mode.enabled=true gets transient
# treatment. Falls through silently if jq is unavailable (treats as full run —
# the agent inside the skill is responsible for not invoking persist-history
# for a known delta run, but this is defence-in-depth).
if command -v jq >/dev/null 2>&1; then
  if jq -e '.delta_mode.enabled == true' "$SCORE" >/dev/null 2>&1; then
    echo "HISTORY: $SKILL delta-mode run — skipping persistence (transient by design)"
    exit 0
  fi
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$REPO_ROOT" ]; then
  exit 0  # Not in a git repo; nowhere to persist.
fi

HIST_DIR="$REPO_ROOT/.qa-team"
mkdir -p "$HIST_DIR" 2>/dev/null || exit 0

COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "uncommitted")
TS=$(date -u +%Y%m%dT%H%M%SZ)
KEY="${SKILL}-${COMMIT}-${TS}"

cp "$SCORE" "$HIST_DIR/${KEY}.json" 2>/dev/null || exit 0
[ -f "$REPORT" ] && cp "$REPORT" "$HIST_DIR/${KEY}.md" 2>/dev/null || true

# `ln -sf` to update the latest pointer atomically (sf overwrites on macOS+Linux).
ln -sf "${KEY}.json" "$HIST_DIR/${SKILL}-latest.json" 2>/dev/null || true

echo "HISTORY: persisted to $HIST_DIR/${KEY}.{json,md}"
exit 0
