  { find . -name "*.csproj" ! -path "*/obj/*" 2>/dev/null | xargs grep -il "MSTest" 2>/dev/null | grep -q '.' && echo "CS_FW: mstest"; } || \
  echo "CS_FW: nunit"

# --- Target language ---
