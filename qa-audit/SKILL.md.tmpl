## Preamble (run first)

```bash
_TMP="${TEMP:-${TMP:-/tmp}}"
_DATE=$(date +%Y-%m-%d)
_BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
echo "BRANCH: $_BRANCH"

# --- Test file discovery by layer ---
echo "--- TEST INVENTORY ---"
_UNIT=$(find . \( \
  -path "*/unit/*.spec.*" -o -path "*/unit/*.test.*" \
  -o -name "*.unit.spec.*" -o -name "*.unit.test.*" \
  -o -path "*/__tests__/unit*" \
  \) ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')
_INTEG=$(find . \( \
  -path "*/integration/*.spec.*" -o -path "*/integration/*.test.*" \
  -o -name "*.integration.spec.*" -o -name "*.integration.test.*" \
  -o -path "*/__tests__/integration*" \
  \) ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')
_E2E=$(find . \( \
  -path "*/e2e/*.spec.*" -o -path "*/e2e/*.test.*" \
  -o -name "*.e2e.spec.*" -o -name "*.e2e.test.*" \
  -o -path "*/tests/e2e*" \
  \) ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')
_ALL_TESTS=$(find . \( \
  -name "*.spec.ts" -o -name "*.spec.js" \
  -o -name "*.test.ts" -o -name "*.test.js" \
  -o -name "*_test.py" -o -name "test_*.py" \
  -o -name "*Test.java" -o -name "*_spec.rb" \
  -o -name "*Tests.cs" -o -name "*Test.cs" -o -name "*Spec.cs" \
  \) ! -path "*/node_modules/*" ! -path "*/obj/*" 2>/dev/null | wc -l | tr -d ' ')
echo "UNIT: $_UNIT  INTEGRATION: $_INTEG  E2E: $_E2E  TOTAL: $_ALL_TESTS"

# --- Framework detection ---
echo "--- FRAMEWORK ---"
grep -ql '"jest"\|"vitest"\|"@testing-library"' package.json 2>/dev/null && echo "FRAMEWORK: jest/vitest (JS/TS)"
ls pytest.ini conftest.py pyproject.toml 2>/dev/null | head -1 | grep -q '.' && echo "FRAMEWORK: pytest (Python)"
ls pom.xml build.gradle 2>/dev/null | head -1 | grep -q '.' && echo "FRAMEWORK: JUnit (Java)"
ls Gemfile 2>/dev/null | grep -q '.' && echo "FRAMEWORK: RSpec (Ruby)"
find . -name "*.csproj" ! -path "*/obj/*" 2>/dev/null | grep -q '.' && echo "FRAMEWORK: .NET (C#)" && \
  { find . -name "*.csproj" ! -path "*/obj/*" 2>/dev/null | xargs grep -il "xunit" 2>/dev/null | grep -q '.' && echo "CS_FW: xunit"; } || \
  { find . -name "*.csproj" ! -path "*/obj/*" 2>/dev/null | xargs grep -il "MSTest" 2>/dev/null | grep -q '.' && echo "CS_FW: mstest"; } || \
  echo "CS_FW: nunit"

# --- Target language ---
echo "--- LANGUAGE ---"
_TARGET_LANG="typescript"
find . -name "pom.xml" ! -path "*/node_modules/*" 2>/dev/null | grep -q '.' && _TARGET_LANG="java"
find . \( -name "requirements.txt" -o -name "pyproject.toml" \) \
  ! -path "*/node_modules/*" 2>/dev/null | grep -q '.' && _TARGET_LANG="python"
find . -name "*.csproj" ! -path "*/obj/*" 2>/dev/null | grep -q '.' && _TARGET_LANG="csharp"
[ -f "Gemfile" ] && _TARGET_LANG="ruby"
echo "TARGET_LANG: $_TARGET_LANG"

# --- Coverage configuration ---
echo "--- COVERAGE ---"
grep -ql '"coverage"\|"nyc"\|"c8"' package.json 2>/dev/null && echo "COVERAGE_TOOL: nyc/c8"
ls .nycrc .nycrc.json jest.config.ts jest.config.js vitest.config.ts vitest.config.js 2>/dev/null | head -3
grep -r "coverageThreshold" --include="*.json" --include="*.ts" --include="*.js" \
  ! -path "*/node_modules/*" 2>/dev/null | head -3
grep -ql "pytest-cov\|coverage\[" requirements.txt pyproject.toml 2>/dev/null && echo "COVERAGE_TOOL: pytest-cov"
grep -r "\-\-cov-fail-under" --include="*.ini" --include="*.cfg" --include="*.toml" \
  2>/dev/null | head -3

# --- Flakiness signals ---
echo "--- FLAKINESS SIGNALS ---"
_SLEEP_COUNT=$(grep -r "sleep\|setTimeout\|Thread\.sleep\|time\.sleep" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')
_RETRY_COUNT=$(grep -r "retry\|retries\|flaky\|\.skip\b\|\.only\b\|xtest\b\|xit\b\|xdescribe\b\|@Ignore\b\|\[Ignore\]\|\[Skip\]\|pytest\.mark\.skip\|pytest\.mark\.xfail\|jest\.retryTimes\|retries:.*[1-9]" \
  --include="*.spec.*" --include="*.test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')
echo "SLEEP_CALLS: $_SLEEP_COUNT  RETRY_MARKS: $_RETRY_COUNT"

# --- BDD signals ---
echo "--- BDD ---"
_FEATURES=$(find . -name "*.feature" ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')
echo "FEATURE_FILES: $_FEATURES"
ls cucumber.js cypress.json jest-cucumber.config.* 2>/dev/null | head -2

# --- CI config ---
echo "--- CI ---"
ls .github/workflows/*.yml .circleci/config.yml .gitlab-ci.yml azure-pipelines.yml \
  Jenkinsfile 2>/dev/null | head -5

# --- MULTI-REPO SUPPORT ---
# Set QA_EXTRA_PATHS (space-separated absolute paths) to scan tests in other repos
# e.g.: export QA_EXTRA_PATHS="/path/to/e2e-repo /path/to/api-tests-repo"
if [ -n "$QA_EXTRA_PATHS" ]; then
  echo "MULTI_REPO_PATHS: $QA_EXTRA_PATHS"
  for _qr in $QA_EXTRA_PATHS; do
    _extra=$(find "$_qr" \( \
      -name "*.spec.ts" -o -name "*.spec.js" -o -name "*.test.ts" -o -name "*.test.js" \
      -o -name "*_test.py" -o -name "test_*.py" -o -name "*Test.java" \
      -o -name "*Tests.cs" -o -name "*_spec.rb" \) \
      ! -path "*/node_modules/*" ! -path "*/obj/*" 2>/dev/null | wc -l | tr -d ' ')
    echo "EXTRA_REPO $(basename "$_qr"): $_extra test files — $_qr"
  done
fi

echo "--- DONE ---"
```

If `_ALL_TESTS` is 0: warn the user that no test files were found. Recommend starting
with `/qa-methodology-refine test-pyramid` to understand testing strategy. Skip Phases
2–4 and produce a "No tests found" report.

If `MULTI_REPO_PATHS` output appeared: when sampling test files in Phase 1 and running
checks in Phase 2, include files from those extra paths. Language detection (`TARGET_LANG`)
uses CWD (the main application repository).

## Phase 1 — Test Inventory

Sample test files across all layers. Read up to 3 files from each detected layer:

```bash
# Sample unit tests
find . \( -path "*/unit/*.spec.*" -o -name "*.unit.spec.*" -o -name "*.unit.test.*" \) \
  ! -path "*/node_modules/*" 2>/dev/null | head -3

# Sample integration tests
find . \( -path "*/integration/*.spec.*" -o -name "*.integration.spec.*" \) \
  ! -path "*/node_modules/*" 2>/dev/null | head -3

# Sample e2e tests
find . \( -path "*/e2e/*.spec.*" -o -name "*.e2e.spec.*" \) \
  ! -path "*/node_modules/*" 2>/dev/null | head -3

# Sample unclassified tests (top-level spec files)
find . -maxdepth 4 \( -name "*.spec.ts" -o -name "*.spec.js" -o -name "*.test.ts" \) \
  ! -path "*/node_modules/*" ! -path "*/e2e/*" ! -path "*/unit/*" ! -path "*/integration/*" \
  2>/dev/null | head -5
```

Read the sampled files. For each, note the observed pattern and classify:

**Layer classification heuristics** (when file path isn't conclusive):
- Imports a real HTTP client (`fetch`, `axios`, `requests`, `RestAssured`) without mocking → **integration**
- Imports `playwright`, `cypress`, `selenium`, `detox`, `appium` → **e2e**
- Mocks all I/O dependencies → **unit**
- Mix of real and mocked dependencies → **integration**

Build the inventory table:

```
Layer        | Count | % of total | Sample files
-------------|-------|------------|-------------
Unit         |   N   |   N%       | path/to/file.spec.ts
Integration  |   N   |   N%       | path/to/file.spec.ts
E2E          |   N   |   N%       | path/to/file.spec.ts
Unclassified |   N   |   N%       | path/to/file.spec.ts
```

Ideal pyramid: **unit > 60%**, **integration 20–35%**, **e2e < 20%**.

## Phase 2 — Methodology Checks

Run these static checks and record concrete findings with file locations.

**Check 1: Test naming quality**

```bash
# Find vague test names
grep -rn "it\(\|test\(\|def test_\|@Test" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | \
  grep -iE "'test[0-9]*'|\"test[0-9]*\"|'it works'|'should work'|'does something'|'test this'" | head -10
```

Good: `"returns 401 when token is expired"` — describes behavior + expected outcome.
Bad: `"test auth"`, `"it works"`, `"test1"`.

**Check 2: Arrange-Act-Assert / Given-When-Then structure**

```bash
grep -rn "// Arrange\|// Act\|// Assert\|// Given\|// When\|// Then\|#arrange\|#act\|#assert" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | wc -l
```

Low count doesn't mean bad tests — read 3 unstructured test files to see if the
structure is implied but unwritten.

**Check 3: Test isolation — shared mutable state**

```bash
# let/var at describe scope (not reset in beforeEach) — JS/TS
grep -rn "^\s*let \|^\s*var " \
  --include="*.spec.ts" --include="*.spec.js" --include="*.test.ts" \
  ! -path "*/node_modules/*" 2>/dev/null | head -10

# beforeEach cleanup presence
grep -rn "beforeEach\|afterEach\|setUp\|tearDown\|setup_method\|teardown_method" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | wc -l
```

**Check 4: Sleep / timing dependencies (flakiness risk)**

```bash
grep -rn "sleep\|setTimeout.*[0-9]\{3,\}\|Thread\.sleep\|time\.sleep\|asyncio\.sleep" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | head -10
```

Each hardcoded sleep in a test is a flakiness risk. Report count + locations.

**Check 5: Test data strategy**

```bash
# Hardcoded literals in test bodies
_HARDCODED=$(grep -r "@example\.com\|password123\|test-user-[0-9]\|admin@\|\"admin\"" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')

# Factory / fixture usage
_FACTORY=$(grep -r "factory\|faker\|fixture\|\.build(\|\.create(\|Factory\.\|Faker\." \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | wc -l | tr -d ' ')

echo "HARDCODED: $_HARDCODED  FACTORY: $_FACTORY"
```

**Check 6: Coverage configuration**

Read the coverage config file (jest.config.ts, vitest.config.ts, pytest.ini, etc.).
Check:
- Coverage enabled: yes/no
- Thresholds configured: yes/no (if yes, what values?)
- Branch coverage measured: yes/no

**Check 7: CI test integration**

```bash
# Artifact-on-failure signals (screenshots, videos, test reports)
grep -r "upload-artifact\|store_artifacts\|publishTestResults\|junit\|screenshot\|video\|allure\|test-results" \
  --include="*.yml" --include="*.yaml" 2>/dev/null | head -5
```

Read the first CI config file found. Check:
- Tests run on every PR/push: yes/no
- Tests gate merge (required status check): inferred
- Separate stages (fast unit first, slow e2e last): yes/no
- Artifacts on failure (screenshots, videos, test reports uploaded): yes/no — relevant for integration/e2e debugging; less critical for unit tests

**Check 8: Assertion quality**

```bash
# Weak assertions — presence-only, not verifying exact values or behaviour
grep -rn "\.not\.toBeNull\(\)\|\.not\.toBeUndefined\(\)\|\.toBeDefined\(\)\|notBeNull\|assertNotNull\|IsNotNull\|Assert\.NotNull\|should\.exist\b\|is_not None\b\|ShouldNotBeNull\|should_not be_nil\|assertIsNotNone" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | head -15
```

Good: `expect(user.email).toBe('test@example.com')` — verifies the exact value.
Bad: `expect(user).not.toBeNull()`, `assertNotNull(result)` — only confirms the object exists; does not verify its content or behaviour.

Report count + locations. One or two null-guard assertions may be acceptable as a precondition; a pattern of *only* null-checks suggests tests that pass without actually exercising expected behaviour.

**Check 9: Positive/negative test balance**

```bash
# Test names describing negative / error paths
_NEG_TESTS=$(grep -rn "it(\|test(\|def test_\|@Test\b" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | \
  grep -iE "error|invalid|fail|reject|forbidden|unauthori[sz]ed|denied|missing|wrong|bad|should.not|cannot|throws?" | wc -l | tr -d ' ')

# Test names describing positive / happy paths
_POS_TESTS=$(grep -rn "it(\|test(\|def test_\|@Test\b" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | \
  grep -iE "success|returns?|creates?|gets?|fetches?|updates?|deletes?|should.*return|should.*create|should.*allow|200|201|204" | wc -l | tr -d ' ')
echo "POSITIVE_TEST_NAMES: $_POS_TESTS  NEGATIVE_TEST_NAMES: $_NEG_TESTS"
```

Healthy suite: both counts are non-zero and roughly balanced relative to suite size.
Red flag: `_NEG_TESTS = 0` — suite tests only the happy path; all error-case coverage is missing.
Red flag: `_NEG_TESTS >> _POS_TESTS` — may indicate over-focus on error handling while neglecting core behaviour tests.

**Check 10: Retry / ignore / skip markers**

```bash
grep -rn "\.skip\b\|\.only\b\|xtest\b\|xit\b\|xdescribe\b\|@Ignore\b\|\[Ignore\]\|\[Skip\]\|pytest\.mark\.skip\|pytest\.mark\.xfail\|pending()\|jest\.retryTimes\|retries:\s*[1-9]\|flaky" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | head -20
```

- **`.skip` / `@Ignore` / `[Ignore]`** — silently excludes tests; acceptable with a comment explaining why, problematic when used to suppress a failing test without a tracking issue
- **`.only`** — scopes the run to a single test; almost always a committed mistake
- **`retryTimes` / `retries:`** — masks flaky tests by hiding the root cause; prefer fixing the underlying race condition or timing issue instead
- **`pytest.mark.xfail`** — acceptable when the failure is documented and expected; flag if used without a `reason=` string

Report each occurrence with file and line. Any `.only` in committed code is a definite bug.

**Check 11: Parallelization safety**

```bash
# Hardcoded shared resources that cause worker conflicts under parallel execution
grep -rn "localhost:[0-9]\{4,\}\|\"port\".*[0-9]\{4,\}\|database.*['\"]test['\"]" \
  --include="*.spec.*" --include="*.test.*" --include="*_test.*" \
  ! -path "*/node_modules/*" 2>/dev/null | head -10

# Sequential / no-parallel flags in config — sign that tests force serial execution
grep -r "\-\-runInBand\|runInBand\|maxWorkers.*[\"']1[\"']\|workers.*=.*1\b\|singleThread\|sequentialTests" \
  --include="*.json" --include="*.ts" --include="*.js" --include="*.yml" --include="*.yaml" \
  ! -path "*/node_modules/*" 2>/dev/null | head -5
```

**Distinction from Check 7**: Check 7 looks at whether CI *runs* tests in parallel (good for speed). Check 11 looks at whether *test code* is safe to run in parallel.

Red flags: hardcoded ports or database names shared across test workers; `--runInBand` / `maxWorkers=1` suppressing parallelism to paper over race conditions instead of fixing them.
Green: tests use randomised/ephemeral ports, per-worker databases, or have no shared I/O resources.

