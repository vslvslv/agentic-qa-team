_STRYKER_AVAILABLE=0
grep -q '"@stryker-mutator/' package.json 2>/dev/null && _STRYKER_AVAILABLE=1
echo "STRYKER_AVAILABLE: $_STRYKER_AVAILABLE"

_PITEST_AVAILABLE=0
[ -f pom.xml ] && grep -q "pitest" pom.xml 2>/dev/null && _PITEST_AVAILABLE=1
